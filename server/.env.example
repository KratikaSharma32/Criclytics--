# --- Server ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Database ---
# MongoDB Atlas connection string. If left empty, the server falls back to
# an in-memory data store so you can still run auth + favorites for local dev.
MONGO_URI=

# --- Auth ---
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_too
JWT_REFRESH_EXPIRES_IN=30d

# --- Redis (optional — in-memory cache is used automatically if empty) ---
REDIS_URL=

# --- Cricket data APIs ---
# Primary
SPORTMONKS_API_TOKEN=
SPORTMONKS_BASE_URL=https://cricket.sportmonks.com/api/v2.0
# Backup 1
CRICAPI_KEY=
CRICAPI_BASE_URL=https://api.cricapi.com/v1
# Backup 2
CRICKETDATA_API_KEY=
CRICKETDATA_BASE_URL=https://api.cricketdata.org

# --- News ---
GNEWS_API_KEY=
GNEWS_BASE_URL=https://gnews.io/api/v4

# --- AI ---
# Set one of these. If both are empty, AI endpoints fall back to a
# rule-based analyzer built from the live match state (still useful, just
# not LLM-generated).
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Payments ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=

# --- Notifications ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Email (password reset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CricLive <no-reply@criclive.app>"
